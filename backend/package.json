{
  "name": "krishinexus-backend",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "ingest": "node ingestion/runIngestion.js",
    "seed:bdapi": "node db/seeds/seedDivisions.js && node db/seeds/seedDistricts.js && node db/seeds/warehouseStocks.js",
