{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "frontend/assets/$1"
    },
    {
      "src": "/bd-districts.geojson",
      "dest": "frontend/bd-districts.geojson"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/weather-refresh",
      "schedule": "0 0 * * *"
    }
  ]
}
